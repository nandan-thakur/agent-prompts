{
  "hooks": {
    "PostToolUse": [
      {
        "type": "command",
        "command": "./scripts/lint-on-save.sh",
        "windows": "powershell -File scripts\\lint-on-save.ps1",
        "timeout": 30
      }
    ],
    "PreToolUse": [
      {
        "type": "command",
        "command": "./scripts/block-dangerous.sh",
        "windows": "powershell -File scripts\\block-dangerous.ps1",
        "timeout": 5
      }
    ],
    "SessionStart": [
      {
        "type": "command",
        "command": "./scripts/inject-project-context.sh",
        "windows": "powershell -File scripts\\inject-project-context.ps1",
        "timeout": 10
      }
    ]
  }
}
